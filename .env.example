# CampusIQ — Supabase PostgreSQL Connection
# Get this from: Supabase Dashboard → Settings → Database → Connection string → URI
# Example: postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:6543/postgres
SUPABASE_DB_URL=postgresql://postgres:your-password@your-project.supabase.co:6543/postgres

# Alternative names (some setups use these)
# DATABASE_URL=postgresql://postgres:your-password@your-project.supabase.co:6543/postgres

# Optional: Anthropic AI key for Papi AI
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: OpenAI key (fallback if Anthropic is not set)
# OPENAI_API_KEY=sk-...

# Optional: OpenRouter key (fallback if neither Anthropic nor OpenAI is set)
# OPENROUTER_API_KEY=sk-or-...

# Optional: Override AI model names
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# OPENAI_MODEL=gpt-4o-mini
