{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/frontend/(.*)", "dest": "/public/frontend/$1" },
    { "src": "/backend/(.*)", "dest": "/public/backend/$1" },
    { "src": "/shared/(.*)", "dest": "/public/shared/$1" },
    { "src": "/data/(.*)", "statusCode": 404 },
    { "src": "/", "dest": "/public/index.html" }
  ]
}
