{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node", "config": { "maxDuration": 60 } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.js" },
    { "src": "/frontend/(.*)", "dest": "/public/frontend/$1" },
    { "src": "/backend/(.*)", "dest": "/public/backend/$1" },
    { "src": "/shared/(.*)", "dest": "/public/shared/$1" },
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/apple-touch-icon.png", "dest": "/public/apple-touch-icon.png" },
    { "src": "/icon-192.png", "dest": "/public/icon-192.png" },
    { "src": "/icon-512.png", "dest": "/public/icon-512.png" },
    { "src": "/maskable-512.png", "dest": "/public/maskable-512.png" },
    { "src": "/sw.js", "dest": "/public/sw.js" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
